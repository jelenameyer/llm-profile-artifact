# ----------------------------------------------------------------------------
# Data (hosted on OSF, fetched with download_data.py) -- never committed to git.
# ----------------------------------------------------------------------------
analysis/data/*
!analysis/data/.gitkeep
*.zip

# ----------------------------------------------------------------------------
# Generated results -- reproduced by running the pipeline, not version-tracked.
# Remove these two rules if you DO want to ship the figures/tables in the repo.
# ----------------------------------------------------------------------------
analysis/results/figures/*
!analysis/results/figures/.gitkeep
analysis/results/tables/*
!analysis/results/tables/.gitkeep

# Raw LLM generation outputs (large; regenerated by data_generation/)
data_generation/**/outputs_api/
# Large per-participant human-derived prompts (live on OSF, not git).
# NB: the small task-definition jsonls under direct/tasks/jsonl_data/ ARE committed
# (the analysis reads ipipneo300_items.jsonl and lot_prompts.jsonl from there).
data_generation/hybrid/survey_data/

# ----------------------------------------------------------------------------
# Secrets -- API keys for data_generation must never be committed.
# ----------------------------------------------------------------------------
.env
secrets.json
credentials.json

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
.venv/
venv/
ENV/
env/
.ipynb_checkpoints/

# ----------------------------------------------------------------------------
# OS / editor
# ----------------------------------------------------------------------------
.DS_Store
.vscode/
.idea/

# R history
.Rhistory
